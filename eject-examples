#!/usr/bin/env bash
#
# eject-examples — create standalone sbt projects from Scalus examples.
#
# Usage:
#   ./eject-examples --all <target-dir>
#   ./eject-examples --only <name> [<name> ...] <target-dir>
#   ./eject-examples --list
#
# Each ejected project is a self-contained sbt build that depends on published
# Scalus artifacts, configures the Scalus compiler plugin, and enables
# ScalusBlueprintPlugin (so `sbt blueprint` and `sbt deploy` work out of the box).

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
EXAMPLES_ROOT="$SCRIPT_DIR/scalus-examples/jvm/src/main/scala/scalus/examples"
TESTS_ROOT="$SCRIPT_DIR/scalus-examples/jvm/src/test/scala/scalus/examples"

# Known good snapshot version (update on tagged releases).
SCALUS_VERSION="0.16.0+259-683121c7-SNAPSHOT"

# Read sbt version from this repo so ejected projects use the same.
SBT_VERSION="$({ grep -E '^sbt\.version' "$SCRIPT_DIR/project/build.properties" \
    || true; } | cut -d= -f2 | tr -d ' ')"
SBT_VERSION="${SBT_VERSION:-1.12.9}"

SCALA_VERSION="3.3.7"

EXCLUDED_EXAMPLES="cape"

# Examples that need sources from other examples bundled in.
# Format: "example:dep1,dep2"
BUNDLED_DEPS="storage:linkedlist"

usage() {
    cat <<EOF
Usage:
  $(basename "$0") [--scalus-version V] --all <target-dir>
  $(basename "$0") [--scalus-version V] --only <name> [<name> ...] <target-dir>
  $(basename "$0") --list

Options:
  --scalus-version Override the Scalus version pinned in the generated project.
                   Default: \`val scalusStableVersion\` from build.sbt.
                   Use a locally-published SNAPSHOT (e.g. from \`sbtn publishLocal\`)
                   when the target version isn't on Maven Central yet.
  --all            Eject every directory-based example.
  --only NAMES...  Eject only the named examples (last arg is target dir).
  --list           Print all available examples and exit.

Each example becomes <target-dir>/<kebab-name>/scalus/ with its own build.sbt,
project/, sources, tests, and README.
EOF
}

list_examples() {
    find "$EXAMPLES_ROOT" -mindepth 1 -maxdepth 1 -type d \
        -exec basename {} \; | sort | while IFS= read -r name; do
        case " $EXCLUDED_EXAMPLES " in
            *" $name "*) ;;
            *) echo "$name" ;;
        esac
    done
}

# Maps source directory names to kebab-case output names
# (matching the Cardano Foundation convention).
kebab_name() {
    local name="$1"
    case "$name" in
        amm)                    echo "constant-product-amm" ;;
        anonymousdata)          echo "anonymous-data" ;;
        atomictransactions)     echo "atomic-transaction" ;;
        bilinearAccumulator)    echo "bilinear-accumulator" ;;
        buidlerfest)            echo "buidlerfest" ;;
        crowdfunding)           echo "crowdfund" ;;
        decentralizedidentity)  echo "decentralized-identity" ;;
        editablenft)            echo "editable-nft" ;;
        linkedlist)             echo "linked-list" ;;
        paymentsplitter)        echo "payment-splitter" ;;
        simpletransfer)         echo "simple-transfer" ;;
        simplewallet)           echo "simple-wallet" ;;
        upgradeableproxy)       echo "upgradable-proxy" ;;
        *)                      echo "$name" ;;
    esac
}

# ---- generators -------------------------------------------------------------

detect_extra_deps() {
    local src_dir="$1"
    local test_dir="$2"
    local extras=()
    local scan_dirs=("$src_dir")
    if [[ -d "$test_dir" ]]; then
        scan_dirs+=("$test_dir")
    fi
    for d in "${scan_dirs[@]}"; do
        if grep -rqE '^[[:space:]]*import[[:space:]]+scalus\.bloxbean' "$d" 2>/dev/null; then
            extras+=( '"org.scalus" %% "scalus-bloxbean-cardano-client-lib" % scalusVersion' )
            break
        fi
    done
    for d in "${scan_dirs[@]}"; do
        if grep -rqE '^[[:space:]]*import[[:space:]]+scalus\.patterns' "$d" 2>/dev/null; then
            extras+=( '"org.scalus" %% "scalus-design-patterns" % scalusVersion' )
            break
        fi
    done
    if (( ${#extras[@]} )); then
        printf '%s\n' "${extras[@]}"
    fi
}

gen_snapshot_resolver() {
    if [[ "$SCALUS_VERSION" == *SNAPSHOT* ]]; then
        cat <<'BLOCK'
// TODO: switch to a released version and remove this resolver
resolvers += "Sonatype Central Snapshots" at "https://central.sonatype.com/repository/maven-snapshots/"
BLOCK
    fi
}

gen_build_sbt() {
    local name="$1" src_dir="$2" test_dir="$3"
    local extras
    extras="$(detect_extra_deps "$src_dir" "$test_dir")"
    local extra_lines=""
    if [[ -n "$extras" ]]; then
        while IFS= read -r dep; do
            extra_lines+=",
            $dep"
        done <<< "$extras"
    fi
    cat <<EOF
ThisBuild / scalaVersion := "$SCALA_VERSION"
ThisBuild / organization := "org.example"
ThisBuild / version      := "0.1.0-SNAPSHOT"

$(gen_snapshot_resolver)
val scalusVersion = "$SCALUS_VERSION"

lazy val root = (project in file("."))
    .enablePlugins(ScalusBlueprintPlugin)
    .settings(
        name := "$name",
        Compile / scalaSource := baseDirectory.value,
        Compile / unmanagedSourceDirectories := Seq(baseDirectory.value),
        Compile / unmanagedSources / excludeFilter := new SimpleFileFilter(_.toPath.startsWith((baseDirectory.value / "test").toPath)),
        Test / scalaSource := baseDirectory.value / "test",
        Test / unmanagedSourceDirectories := Seq(baseDirectory.value / "test"),
        scalacOptions ++= Seq("-deprecation", "-feature"),
        addCompilerPlugin(("org.scalus" %% "scalus-plugin" % scalusVersion).cross(CrossVersion.full)),
        libraryDependencies ++= Seq(
            "org.scalus" %% "scalus"                % scalusVersion,
            "org.scalus" %% "scalus-cardano-ledger" % scalusVersion,
            "org.scalus" %% "scalus-testkit"         % scalusVersion % Test,
            "org.scalatest" %% "scalatest"           % "3.2.19"     % Test$extra_lines
        )
    )
EOF
}

gen_plugins_sbt() {
    cat <<EOF
$(gen_snapshot_resolver)
addSbtPlugin("org.scalus" % "scalus-sbt-plugin" % "$SCALUS_VERSION")
EOF
}

gen_build_properties() {
    cat <<EOF
sbt.version=$SBT_VERSION
EOF
}

gen_gitignore() {
    cat <<'EOF'
target/
project/target/
project/project/
.bsp/
.bloop/
.metals/
.idea/
.vscode/
EOF
}

gen_getting_started() {
    local name="$1"
    cat <<EOF
# Getting Started

Standalone Scalus example, ejected from
[scalus3/scalus](https://github.com/scalus3/scalus).

## Build

\`\`\`sh
sbt compile
\`\`\`

## Test

\`\`\`sh
sbt test
\`\`\`

## Generate a CIP-57 blueprint

\`\`\`sh
sbt blueprint
\`\`\`

Blueprint JSON is written to
\`target/scala-$SCALA_VERSION/classes/META-INF/scalus/blueprints/<Contract>.json\`.

## Deploy as a reference script

Requires a Blockfrost project id and a funded wallet mnemonic on the chosen network.

\`\`\`sh
sbt "deploy <ContractName> --network preview \\
    --blockfrost-key <project-id> \\
    --mnemonic '<24 words>'"
\`\`\`

Or via environment variables:

\`\`\`sh
export CARDANO_NETWORK=preview
export BLOCKFROST_API_KEY=<project-id>
export CARDANO_MNEMONIC='<24 words>'
sbt "deploy <ContractName>"
\`\`\`

The contract is deployed as a reference script UTxO at the sender's own base
address; the transaction hash is printed on success.

## Pinned versions

- Scalus: \`$SCALUS_VERSION\`
- Scala:  \`$SCALA_VERSION\`
- sbt:    \`$SBT_VERSION\`
EOF
}

# Rewrites package declarations: scalus.examples.X -> X
rewrite_packages() {
    local dir="$1"
    while IFS= read -r -d '' f; do
        sed -i 's/^package scalus\.examples\./package /' "$f"
        sed -i 's/import scalus\.examples\./import /' "$f"
    done < <(find "$dir" -name '*.scala' -print0)
}

# Returns bundled dependency names for an example, if any.
get_bundled_deps() {
    local name="$1"
    for entry in $BUNDLED_DEPS; do
        local key="${entry%%:*}"
        local deps="${entry#*:}"
        if [[ "$key" == "$name" ]]; then
            echo "$deps" | tr ',' ' '
            return
        fi
    done
}

# ---- core -------------------------------------------------------------------

eject_one() {
    local name="$1" target_root="$2"
    local src_dir="$EXAMPLES_ROOT/$name"
    local test_dir="$TESTS_ROOT/$name"
    if [[ ! -d "$src_dir" ]]; then
        echo "error: example '$name' not found at $src_dir" >&2
        return 1
    fi

    local out_name
    out_name="$(kebab_name "$name")"
    local project_dir="$target_root/$out_name"
    if [[ -e "$project_dir" ]]; then
        echo "error: $project_dir already exists, refusing to overwrite" >&2
        return 1
    fi

    mkdir -p "$project_dir/project"

    # Copy main sources (flat, next to build.sbt)
    find "$src_dir" -maxdepth 1 -name '*.scala' -exec cp {} "$project_dir/" \;

    # Copy bundled dependency sources into their own package dirs
    local deps
    deps="$(get_bundled_deps "$name")"
    if [[ -n "$deps" ]]; then
        for dep in $deps; do
            local dep_src="$EXAMPLES_ROOT/$dep"
            if [[ -d "$dep_src" ]]; then
                mkdir -p "$project_dir/$dep"
                find "$dep_src" -maxdepth 1 -name '*.scala' -exec cp {} "$project_dir/$dep/" \;
            fi
            local dep_test="$TESTS_ROOT/$dep"
            if [[ -d "$dep_test" ]]; then
                mkdir -p "$project_dir/test/$dep"
                find "$dep_test" -maxdepth 1 -name '*.scala' -exec cp {} "$project_dir/test/$dep/" \;
            fi
        done
    fi

    # Copy test sources
    if [[ -d "$test_dir" ]]; then
        mkdir -p "$project_dir/test"
        find "$test_dir" -maxdepth 1 -name '*.scala' -exec cp {} "$project_dir/test/" \;
    fi

    # Rewrite package declarations
    rewrite_packages "$project_dir"

    # Generate build files
    gen_build_sbt "$out_name" "$src_dir" "$test_dir" > "$project_dir/build.sbt"
    gen_plugins_sbt               > "$project_dir/project/plugins.sbt"
    gen_build_properties          > "$project_dir/project/build.properties"
    gen_gitignore                 > "$project_dir/.gitignore"
    gen_getting_started "$out_name" > "$project_dir/GETTING_STARTED.md"

    # Copy the example's own README if it exists
    if [[ -f "$src_dir/README.md" ]]; then
        cp "$src_dir/README.md" "$project_dir/README.md"
    fi

    echo "  ejected $name -> $project_dir"
}

main() {
    if [[ $# -eq 0 ]]; then usage; exit 1; fi

    # Parse flags in any order; collect positional args.
    local mode=""
    local positional=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    usage; exit 0 ;;
            --list)       mode="list"; shift ;;
            --all)        mode="all";  shift ;;
            --only)       mode="only"; shift ;;
            --scalus-version)
                if [[ $# -lt 2 ]]; then
                    echo "error: --scalus-version requires a value" >&2; exit 1
                fi
                SCALUS_VERSION="$2"; shift 2 ;;
            --*)
                echo "error: unknown option '$1'" >&2; usage; exit 1 ;;
            *)
                positional+=( "$1" ); shift ;;
        esac
    done

    if [[ -d "$EXAMPLES_ROOT" ]]; then :; else
        echo "error: examples root not found: $EXAMPLES_ROOT" >&2
        exit 1
    fi

    local failures=0
    case "$mode" in
        list)
            while IFS= read -r name; do
                printf "%-25s -> %s\n" "$name" "$(kebab_name "$name")"
            done < <(list_examples) ;;
        all)
            if [[ ${#positional[@]} -ne 1 ]]; then
                echo "error: --all takes exactly one argument: <target-dir>" >&2
                exit 1
            fi
            local target="${positional[0]}"
            mkdir -p "$target"
            echo "ejecting all examples to $target (scalus $SCALUS_VERSION)"
            while IFS= read -r name; do
                eject_one "$name" "$target" || failures=$((failures + 1))
            done < <(list_examples)
            ;;
        only)
            if [[ ${#positional[@]} -lt 2 ]]; then
                echo "error: --only requires at least one example name and a target dir" >&2
                exit 1
            fi
            local target="${positional[${#positional[@]}-1]}"
            local names=( "${positional[@]:0:${#positional[@]}-1}" )
            mkdir -p "$target"
            echo "ejecting ${#names[@]} example(s) to $target (scalus $SCALUS_VERSION)"
            for name in "${names[@]}"; do
                eject_one "$name" "$target" || failures=$((failures + 1))
            done
            ;;
        "")
            usage; exit 1 ;;
    esac

    if [[ $failures -gt 0 ]]; then
        echo "done with $failures failure(s); see messages above" >&2
    fi
}

main "$@"
